                |  в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қ
            .terminal-output#terminal-output
            .terminal-input-line
              span.terminal-prompt $&nbsp;
              input.terminal-input#terminal-input(type='text' autocomplete='off' spellcheck='false' placeholder='иҫ“е…Ҙ help жҹҘзңӢеҸҜз”Ёе‘Ҫд»Ө...')
      .home-status-widget
        .status-panel
          .status-panel__header
            .status-panel__title
              i.fas.fa-microchip
              span SYS_MONITOR
            .status-panel__uptime
              span.uptime-label uptime
              span#status-uptime 00:00:00
          .status-panel__clock
            span#status-clock 00:00:00
          .status-metrics
            .status-metric
              .status-metric__label
                span CPU.LOAD
                span#cpu-value 0%
              .status-metric__bar
                .status-metric__fill#cpu-bar
            .status-metric
              .status-metric__label
                span MEM.USAGE
                span#mem-value 0%
              .status-metric__bar
                .status-metric__fill#mem-bar
            .status-metric
              .status-metric__label
                span NET.SIGNAL
                span#net-value 0%
              .status-metric__bar
                .status-metric__fill#net-bar
          .status-panel__wave
            canvas#status-wave-canvas
          .status-panel__footer
            span.status-panel__telemetry // telemetry В· realtime
            span#status-tx tx 0 kb/s
